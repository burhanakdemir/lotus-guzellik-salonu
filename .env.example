# Docker Desktop: docker compose up -d
DATABASE_URL="postgresql://lotus:lotus_secret@localhost:5434/lotus_salon?schema=public"
# Yerelde db push için (Neon canlıda Direct URL ayrıdır)
DIRECT_URL="postgresql://lotus:lotus_secret@localhost:5434/lotus_salon?schema=public"

# Canlı (docker-compose.prod.yml)
# DATABASE_URL otomatik — postgres servis adı kullanılır
POSTGRES_USER="lotus"
POSTGRES_PASSWORD="degistirin-guclu-sifre"
POSTGRES_DB="lotus_salon"
APP_PORT="3000"

# Canlıda (NODE_ENV=production) zorunlu — yoksa uygulama oturum doğrulamasında hata verir
JWT_SECRET="degistirin-guclu-bir-gizli-anahtar-en-az-32-karakter"
# Google Authenticator (süper admin) — uygulamada görünen ad
TOTP_ISSUER="LOTUS Admin"
ADMIN_EMAIL="admin@lotusguzellik.com"
ADMIN_PASSWORD="Admin123!"
ADMIN_PHONE="05323943686"
ADMIN_NAME="Neşe AKDEMİR"
# Randevu paneli / online randevu — süper admin sekmesi (varsayılan: ADMIN_NAME)
SUPER_ADMIN_PANEL_NAME="Neşe Akdemir"

# Twilio (ileride SMS hatırlatma)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

NEXT_PUBLIC_SALON_NAME="LOTUS BAYANKUAFÖRÜ & GÜZELLİK SALONU"

# Web Push (tarayıcı bildirimleri) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@lotusguzellik.com"

# Çoklu admin (Faz 2+) — false iken mevcut tek süper admin davranışı
MULTI_ADMIN_ENABLED="false"
# true iken seed süper admin için randevu profili oluşturur (ilk sırada)
# true ise seed'e 5 yardımcı admin ekler (5320000001–5, şifre: Staff123!)
MULTI_ADMIN_SEED_STAFF="false"
STAFF_ADMIN_PASSWORD="Staff123!"

# İlk canlı kurulumda seed zorla (DB doluysa atlanır; container yeniden başlayınca admin düzenlemeleri korunur)
# RUN_SEED="true"

# --- Render + Neon (düşük maliyet canlı, ~$7/ay) ---
# 1) neon.tech → ücretsiz PostgreSQL → Connection string kopyala
# 2) Render Blueprint → DATABASE_URL = pooled, DIRECT_URL = direct (Neon panelinde ikisi de var)
# 3) Render'da elle: ADMIN_PASSWORD, ADMIN_PHONE
# DATABASE_URL (pooled, uygulama): postgresql://...@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL (direct, db push):     postgresql://...@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Neon uyuyorsa veya bağlantı koparsa Render log: "Can't reach database server" — Neon panelinden projeyi kontrol edin.
# Upload kalıcılığı: render.yaml disk → public/uploads
# Build: npm ci && npm run build  |  Start: npm run start:render
