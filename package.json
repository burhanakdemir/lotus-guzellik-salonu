{
  "name": "lotus-guzellik-salonu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/dev-clean.mjs",
    "prebuild": "node scripts/ensure-dirs.mjs && npx tsx scripts/ensure-images.ts",
    "build": "next build",
    "start": "next start",
    "start:prod": "npx tsx scripts/prod-setup.ts && next start",
    "start:render": "npx tsx scripts/prod-setup.ts && next start -H 0.0.0.0",
    "prod:setup": "npx tsx scripts/prod-setup.ts",
    "lint": "next lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run docker:up && npm run prod:setup",
    "images:generate": "tsx scripts/generate-placeholders.ts",
    "images:download": "tsx scripts/download-service-images.ts",
    "images:logo": "node scripts/generate-logo.mjs",
    "images:prepare": "npm run images:download && npm run images:generate && npm run images:logo",
    "images:verify": "tsx scripts/verify-assets.ts",
    "assets:sync": "npx tsx scripts/prune-service-assets.ts && npx tsx scripts/ensure-images.ts",
    "assets:prune": "npx tsx scripts/prune-service-assets.ts",
    "ensure:dirs": "node scripts/ensure-dirs.mjs",
    "db:studio": "prisma studio",
    "theme:save-tema1": "node scripts/save-tema1.mjs",
    "theme:restore-tema1": "node scripts/restore-tema1.mjs",
    "theme:save-tema2": "node scripts/save-tema2.mjs",
    "theme:restore-tema2": "node scripts/restore-tema2.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jose": "^6.0.11",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.42",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3"
  }
}
