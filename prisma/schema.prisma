generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MEMBER
  ADMIN
  STAFF_ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationKind {
  INFO
  CAMPAIGN
  REMINDER
  SYSTEM
}

model User {
  id           String           @id @default(cuid())
  name         String
  phone        String           @unique
  email        String?
  passwordHash String
  role         Role             @default(MEMBER)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  appointments Appointment[]
  discounts    MemberDiscount[]
  reviews      CustomerReview[]
  notifications MemberNotification[]
  pushSubscriptions MemberPushSubscription[]
  notificationPreference MemberNotificationPreference?
  staffAdminProfile      StaffAdminProfile?
  appointmentsApproved   Appointment[]         @relation("AppointmentApprovedBy")
  staffNotifications     StaffNotification[]
  /// Google Authenticator (TOTP) — yalnızca süper admin (ADMIN)
  totpSecret             String?
  totpEnabledAt          DateTime?
}

/// Usta / süper admin panel bildirimleri
model StaffNotification {
  id            String             @id @default(cuid())
  staffId       String?
  staff         StaffAdminProfile? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentId String?
  title         String
  body          String
  link          String?
  readAt        DateTime?
  createdAt     DateTime           @default(now())

  @@index([userId, readAt])
  @@index([staffId, createdAt])
}

/// Usta profili (max 5 aktif — uygulama katmanında sınırlanır)
model StaffAdminProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug         String        @unique
  label        String
  color        String?
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments      Appointment[]
  services          StaffService[]
  staffNotifications StaffNotification[]
  galleryItems      GalleryItem[]
  reviews           CustomerReview[]
  blockedTimeSlots  BlockedTimeSlot[]

  @@index([isActive, sortOrder])
}

/// Ustanın yapabildiği hizmetler (boş = tüm hizmetler)
model StaffService {
  staffId   String
  staff     StaffAdminProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
}

model Service {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  category        String
  description     String
  durationMinutes Int
  price           Float
  /// Hizmetler / randevu vb. (genel site ayarı açıkken)
  showPricePublic      Boolean       @default(true)
  /// Ana sayfa öne çıkan kartlarda
  showPriceOnHomepage  Boolean       @default(false)
  imageUrl        String?
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]
  promotions      PromotionService[]
  discounts       MemberDiscountService[]
  staffCapabilities StaffService[]
}

model Appointment {
  id              String             @id @default(cuid())
  phone           String
  name            String
  userId          String?
  user            User?              @relation(fields: [userId], references: [id])
  serviceId       String
  service         Service            @relation(fields: [serviceId], references: [id])
  assignedStaffId String?
  assignedStaff   StaffAdminProfile? @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)
  date            String
  startTime       String
  endTime         String
  status                AppointmentStatus  @default(PENDING)
  /// Usta veya süper admin onayı
  staffApprovedAt       DateTime?
  staffApprovedByUserId String?
  staffApprovedBy       User?              @relation("AppointmentApprovedBy", fields: [staffApprovedByUserId], references: [id], onDelete: SetNull)
  note                  String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([date, startTime])
  @@index([status, date])
  @@index([phone, date])
  @@index([assignedStaffId])
}

model Promotion {
  id            String             @id @default(cuid())
  title         String
  description   String
  discountType  DiscountType
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  allServices   Boolean            @default(true)
  isActive      Boolean            @default(true)
  bannerUrl     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  services      PromotionService[]
}

model PromotionService {
  promotionId String
  serviceId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
}

model MemberDiscount {
  id            String                  @id @default(cuid())
  userId        String
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  discountType  DiscountType
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  allServices   Boolean                 @default(true)
  singleUse     Boolean                 @default(false)
  usedCount     Int                     @default(0)
  maxUses       Int?
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  services      MemberDiscountService[]
}

model MemberDiscountService {
  discountId String
  serviceId  String
  discount   MemberDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  service    Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([discountId, serviceId])
}

model SalonSettings {
  id              String @id @default("default")
  salonName       String
  city            String
  address         String
  phone           String
  heroTitle       String
  heroSubtitle    String
  aboutContent    String
  instagram       String?
  facebook        String?
  slotInterval         Int     @default(30)
  showServicePrice     Boolean @default(true)
  showServiceDuration  Boolean @default(true)
  mondayOpen      String?
  mondayClose     String?
  tuesdayOpen     String?
  tuesdayClose    String?
  wednesdayOpen   String?
  wednesdayClose  String?
  thursdayOpen    String?
  thursdayClose   String?
  fridayOpen      String?
  fridayClose     String?
  saturdayOpen    String?
  saturdayClose   String?
  sundayOpen      String?
  sundayClose     String?
  /// Ana sayfa hero — 4 işletme görseli (boş = bordo alan)
  showcaseImage1  String?
  showcaseImage2  String?
  showcaseImage3  String?
  showcaseImage4  String?
}

model ClosedDay {
  id     String   @id @default(cuid())
  date   String   @unique
  reason String?
}

/// Admin — belirli gün/saat müşteri randevusuna kapalı (usta veya tüm salon)
model BlockedTimeSlot {
  id              String             @id @default(cuid())
  date            String
  startTime       String
  endTime         String
  assignedStaffId String?
  assignedStaff   StaffAdminProfile? @relation(fields: [assignedStaffId], references: [id], onDelete: Cascade)
  reason          String?
  createdAt       DateTime           @default(now())

  @@index([date, assignedStaffId])
}

model SiteContent {
  id    String @id @default("default")
  key   String @unique
  value String
}

model GalleryItem {
  id              String             @id @default(cuid())
  title           String
  description     String             @default("")
  mediaType       GalleryMediaType
  mediaUrl        String
  sortOrder       Int                @default(0)
  isActive        Boolean            @default(true)
  staffProfileId  String?
  staffProfile    StaffAdminProfile? @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([isActive, sortOrder])
  @@index([staffProfileId, isActive, sortOrder])
}

model CustomerReview {
  id              String             @id @default(cuid())
  content         String
  imageUrls       String[]           @default([])
  status          ReviewStatus       @default(PENDING)
  userId          String?
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffProfileId  String?
  staffProfile    StaffAdminProfile? @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([staffProfileId, status, createdAt])
}

model MemberNotification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  kind      NotificationKind @default(INFO)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

model MemberPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model MemberNotificationPreference {
  userId              String   @id
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled        Boolean  @default(true)
  pushEnabled         Boolean  @default(false)
  pushPromptDismissed Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}
